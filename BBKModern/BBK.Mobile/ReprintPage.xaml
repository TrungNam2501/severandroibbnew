<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BBK.Mobile.ReprintPage"
             Title="In Lại Tem"
             BackgroundColor="{StaticResource PageBackground}">
    <ScrollView>
        <VerticalStackLayout Padding="16,10" Spacing="8">

            <!-- MES + Recipe -->
            <Border StrokeShape="RoundRectangle 10"
                    Stroke="{StaticResource BorderDark}"
                    StrokeThickness="1"
                    BackgroundColor="{StaticResource CardBackground}"
                    Padding="14,10">
                <VerticalStackLayout Spacing="6">
                    <Label Text="MÃ MES"
                           FontSize="11"
                           TextColor="{StaticResource TextMuted}"
                           FontAttributes="Bold"
                           CharacterSpacing="1" />
                    <Picker x:Name="MesPicker"
                            Title="Chọn MES"
                            FontSize="15"
                            TextColor="{StaticResource TextPrimary}"
                            TitleColor="{StaticResource TextMuted}"
                            BackgroundColor="{StaticResource InputBackground}"
                            SelectedIndexChanged="OnMesSelected" />

                    <Label Text="MÃ KEO"
                           FontSize="11"
                           TextColor="{StaticResource TextMuted}"
                           FontAttributes="Bold"
                           CharacterSpacing="1" />
                    <Border StrokeShape="RoundRectangle 8"
                            Stroke="{StaticResource BorderDark}"
                            BackgroundColor="{StaticResource SurfaceElevated}"
                            Padding="10,2"
                            HeightRequest="38">
                        <Entry x:Name="RecipeEntry"
                               Placeholder="Tự động khi chọn MES"
                               PlaceholderColor="{StaticResource TextMuted}"
                               TextColor="{StaticResource Primary}"
                               IsReadOnly="True"
                               FontSize="14"
                               FontAttributes="Bold" />
                    </Border>
                </VerticalStackLayout>
            </Border>

            <!-- Barcode + Printer -->
            <Border StrokeShape="RoundRectangle 10"
                    Stroke="{StaticResource BorderDark}"
                    StrokeThickness="1"
                    BackgroundColor="{StaticResource CardBackground}"
                    Padding="14,10">
                <VerticalStackLayout Spacing="6">
                    <Label Text="MÃ TEM &amp; TRỌNG LƯỢNG"
                           FontSize="11"
                           TextColor="{StaticResource TextMuted}"
                           FontAttributes="Bold"
                           CharacterSpacing="1" />
                    <Picker x:Name="BarcodePicker"
                            Title="Chọn mã tem"
                            FontSize="15"
                            TextColor="{StaticResource TextPrimary}"
                            TitleColor="{StaticResource TextMuted}"
                            BackgroundColor="{StaticResource InputBackground}" />

                    <Label Text="MÁY IN"
                           FontSize="11"
                           TextColor="{StaticResource TextMuted}"
                           FontAttributes="Bold"
                           CharacterSpacing="1" />
                    <Picker x:Name="PrinterPicker"
                            Title="Chọn máy in"
                            ItemDisplayBinding="{Binding Name}"
                            FontSize="15"
                            TextColor="{StaticResource TextPrimary}"
                            TitleColor="{StaticResource TextMuted}"
                            BackgroundColor="{StaticResource InputBackground}" />
                </VerticalStackLayout>
            </Border>

            <!-- Action Buttons -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="8" Padding="0,2">
                <Button Text="In Lại Tem"
                        FontSize="15"
                        FontAttributes="Bold"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="{StaticResource PageBackground}"
                        CornerRadius="10"
                        HeightRequest="44"
                        Clicked="OnReprintClicked" />
                <Button Grid.Column="1"
                        Text="Quay lại"
                        FontSize="13"
                        BackgroundColor="Transparent"
                        TextColor="{StaticResource TextSecondary}"
                        BorderColor="{StaticResource BorderDark}"
                        BorderWidth="1"
                        CornerRadius="10"
                        HeightRequest="44"
                        Clicked="OnBackClicked" />
            </Grid>

            <!-- Loading + Message -->
            <ActivityIndicator x:Name="LoadingIndicator"
                               IsVisible="False"
                               IsRunning="False"
                               Color="{StaticResource Primary}"
                               HeightRequest="24" />
            <Label x:Name="MessageLabel"
                   FontSize="13"
                   TextColor="{StaticResource Warning}"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
