<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BBK.Mobile.ReprintPage"
             Title="In Lại Tem"
             BackgroundColor="{AppThemeBinding Light={StaticResource PageBackground}, Dark={StaticResource PageBackgroundDark}}">
    <ScrollView>
        <VerticalStackLayout Padding="16,10" Spacing="8">

            <!-- MES + Recipe Section -->
            <Border StrokeShape="RoundRectangle 10"
                    Stroke="Transparent"
                    BackgroundColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource CardBackgroundDark}}"
                    Padding="14,10">
                <VerticalStackLayout Spacing="6">
                    <Label Text="Mã MES"
                           FontSize="12"
                           TextColor="{StaticResource Gray400}"
                           FontAttributes="Bold" />
                    <Picker x:Name="MesPicker"
                            Title="Chọn MES"
                            FontSize="15"
                            TextColor="{StaticResource Gray900}"
                            BackgroundColor="{AppThemeBinding Light={StaticResource InputBackground}, Dark={StaticResource InputBackgroundDark}}"
                            SelectedIndexChanged="OnMesSelected" />

                    <Label Text="Mã Keo"
                           FontSize="12"
                           TextColor="{StaticResource Gray400}"
                           FontAttributes="Bold" />
                    <Border StrokeShape="RoundRectangle 8"
                            Stroke="{StaticResource Gray200}"
                            BackgroundColor="{AppThemeBinding Light=#EDF2F7, Dark={StaticResource InputBackgroundDark}}"
                            Padding="10,2"
                            HeightRequest="38">
                        <Entry x:Name="RecipeEntry"
                               Placeholder="Tự động khi chọn MES"
                               IsReadOnly="True"
                               FontSize="14" />
                    </Border>
                </VerticalStackLayout>
            </Border>

            <!-- Barcode + Printer Section -->
            <Border StrokeShape="RoundRectangle 10"
                    Stroke="Transparent"
                    BackgroundColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource CardBackgroundDark}}"
                    Padding="14,10">
                <VerticalStackLayout Spacing="6">
                    <Label Text="Mã Tem &amp; Trọng Lượng"
                           FontSize="12"
                           TextColor="{StaticResource Gray400}"
                           FontAttributes="Bold" />
                    <Picker x:Name="BarcodePicker"
                            Title="Chọn mã tem"
                            FontSize="15"
                            TextColor="{StaticResource Gray900}"
                            BackgroundColor="{AppThemeBinding Light={StaticResource InputBackground}, Dark={StaticResource InputBackgroundDark}}" />

                    <Label Text="Máy In"
                           FontSize="12"
                           TextColor="{StaticResource Gray400}"
                           FontAttributes="Bold" />
                    <Picker x:Name="PrinterPicker"
                            Title="Chọn máy in"
                            ItemDisplayBinding="{Binding Name}"
                            FontSize="15"
                            TextColor="{StaticResource Gray900}"
                            BackgroundColor="{AppThemeBinding Light={StaticResource InputBackground}, Dark={StaticResource InputBackgroundDark}}" />
                </VerticalStackLayout>
            </Border>

            <!-- Action Buttons -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="8" Padding="0,2">
                <Button Text="In Lại Tem"
                        FontSize="15"
                        FontAttributes="Bold"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="White"
                        CornerRadius="10"
                        HeightRequest="44"
                        Clicked="OnReprintClicked" />
                <Button Grid.Column="1"
                        Text="Quay lại"
                        FontSize="14"
                        BackgroundColor="Transparent"
                        TextColor="{StaticResource Gray500}"
                        BorderColor="{StaticResource Gray200}"
                        BorderWidth="1"
                        CornerRadius="10"
                        HeightRequest="44"
                        Clicked="OnBackClicked" />
            </Grid>

            <!-- Loading + Message -->
            <ActivityIndicator x:Name="LoadingIndicator"
                               IsVisible="False"
                               IsRunning="False"
                               Color="{StaticResource Primary}"
                               HeightRequest="24" />
            <Label x:Name="MessageLabel"
                   FontSize="13"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
