<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BBK.Mobile.ReprintPage"
             Title="In Lại Tem"
             BackgroundColor="{StaticResource PageBackground}">
    <ScrollView>
        <VerticalStackLayout Padding="20,12" Spacing="14">

            <!-- MES + Recipe -->
            <Border StrokeShape="RoundRectangle 20"
                    Stroke="Transparent"
                    BackgroundColor="{StaticResource White}"
                    Padding="20,18"
                    Shadow="{OnPlatform Android={Shadow Brush=#10000000, Offset='0,2', Radius=12}}">
                <VerticalStackLayout Spacing="14">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Mã MES"
                               FontSize="13"
                               TextColor="{StaticResource TextSecondary}"
                               FontAttributes="Bold" />
                        <Border StrokeShape="RoundRectangle 14"
                                Stroke="Transparent"
                                BackgroundColor="{StaticResource InputBackground}"
                                Padding="6,0"
                                HeightRequest="48">
                            <Picker x:Name="MesPicker"
                                    Title="Chọn MES"
                                    FontSize="15"
                                    TextColor="{StaticResource TextPrimary}"
                                    TitleColor="{StaticResource TextMuted}"
                                    SelectedIndexChanged="OnMesSelected" />
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="Mã Keo"
                               FontSize="13"
                               TextColor="{StaticResource TextSecondary}"
                               FontAttributes="Bold" />
                        <Border StrokeShape="RoundRectangle 14"
                                Stroke="Transparent"
                                BackgroundColor="{StaticResource SurfaceElevated}"
                                Padding="14,0"
                                HeightRequest="48">
                            <Entry x:Name="RecipeEntry"
                                   Placeholder="Tự động khi chọn MES"
                                   PlaceholderColor="{StaticResource TextMuted}"
                                   TextColor="{StaticResource Primary}"
                                   IsReadOnly="True"
                                   FontSize="15"
                                   FontAttributes="Bold" />
                        </Border>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Barcode + Printer -->
            <Border StrokeShape="RoundRectangle 20"
                    Stroke="Transparent"
                    BackgroundColor="{StaticResource White}"
                    Padding="20,18"
                    Shadow="{OnPlatform Android={Shadow Brush=#10000000, Offset='0,2', Radius=12}}">
                <VerticalStackLayout Spacing="14">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Mã Tem &amp; Trọng Lượng"
                               FontSize="13"
                               TextColor="{StaticResource TextSecondary}"
                               FontAttributes="Bold" />
                        <Border StrokeShape="RoundRectangle 14"
                                Stroke="Transparent"
                                BackgroundColor="{StaticResource InputBackground}"
                                Padding="6,0"
                                HeightRequest="48">
                            <Picker x:Name="BarcodePicker"
                                    Title="Chọn mã tem"
                                    FontSize="15"
                                    TextColor="{StaticResource TextPrimary}"
                                    TitleColor="{StaticResource TextMuted}" />
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="Máy In"
                               FontSize="13"
                               TextColor="{StaticResource TextSecondary}"
                               FontAttributes="Bold" />
                        <Border StrokeShape="RoundRectangle 14"
                                Stroke="Transparent"
                                BackgroundColor="{StaticResource InputBackground}"
                                Padding="6,0"
                                HeightRequest="48">
                            <Picker x:Name="PrinterPicker"
                                    Title="Chọn máy in"
                                    ItemDisplayBinding="{Binding Name}"
                                    FontSize="15"
                                    TextColor="{StaticResource TextPrimary}"
                                    TitleColor="{StaticResource TextMuted}" />
                        </Border>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Action Buttons -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Padding="0,4">
                <Button Text="In Lại Tem"
                        FontSize="16"
                        FontAttributes="Bold"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="White"
                        CornerRadius="16"
                        HeightRequest="52"
                        Clicked="OnReprintClicked" />
                <Button Grid.Column="1"
                        Text="Quay lại"
                        FontSize="14"
                        BackgroundColor="{StaticResource White}"
                        TextColor="{StaticResource TextSecondary}"
                        CornerRadius="16"
                        HeightRequest="52"
                        Shadow="{OnPlatform Android={Shadow Brush=#08000000, Offset='0,1', Radius=6}}"
                        Clicked="OnBackClicked" />
            </Grid>

            <!-- Loading + Message -->
            <ActivityIndicator x:Name="LoadingIndicator"
                               IsVisible="False"
                               IsRunning="False"
                               Color="{StaticResource Primary}"
                               HeightRequest="24" />
            <Label x:Name="MessageLabel"
                   FontSize="13"
                   TextColor="{StaticResource Danger}"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
