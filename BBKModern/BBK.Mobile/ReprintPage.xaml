<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BBK.Mobile.ReprintPage"
             Title="In Lại Tem">
    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="14">
            <Label Text="Chọn Mã MES"
                   FontSize="20"
                   FontAttributes="Bold" />
            <Picker x:Name="MesPicker"
                    Title="Chọn MES"
                    SelectedIndexChanged="OnMesSelected" />
            <Label Text="Mã KEO"
                   FontSize="20"
                   FontAttributes="Bold" />
            <Entry x:Name="RecipeEntry"
                   Placeholder="Mã keo"
                   IsReadOnly="True" />
            <Label Text="Mã Tem Và Trọng Lượng"
                   FontSize="20"
                   FontAttributes="Bold" />
            <Picker x:Name="BarcodePicker"
                    Title="Chọn mã tem" />
            <Label Text="Chọn Máy In"
                   FontSize="20"
                   FontAttributes="Bold" />
            <Picker x:Name="PrinterPicker"
                    Title="Chọn máy in"
                    ItemDisplayBinding="{Binding Name}" />
            <Button Text="In lại tem"
                    FontSize="20"
                    FontAttributes="Bold"
                    Clicked="OnReprintClicked" />
            <Button Text="Quay lại"
                    FontSize="20"
                    FontAttributes="Bold"
                    Clicked="OnBackClicked" />
            <ActivityIndicator x:Name="LoadingIndicator"
                               IsVisible="False"
                               IsRunning="False" />
            <Label x:Name="MessageLabel"
                   TextColor="Red" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
