<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BBK.Mobile.ScanPage"
             Title="Quét in tem">
    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="14">
            <Picker x:Name="MesPicker"
                    Title="Chọn MES"
                    ItemDisplayBinding="{Binding PlanId}" />
            <Entry x:Name="RecipeEntry"
                   Placeholder="Mã keo" />
            <Entry x:Name="PalletEntry"
                   Placeholder="Pallet" />
            <Entry x:Name="WeightEntry"
                   Placeholder="Trọng lượng"
                   Keyboard="Numeric" />
            <Picker x:Name="PrinterPicker"
                    Title="Chọn máy in"
                    ItemDisplayBinding="{Binding Name}" />
            <HorizontalStackLayout Spacing="12">
                <CheckBox x:Name="ReworkCheckBox" />
                <Label Text="Cán đảo"
                       VerticalOptions="Center" />
                <CheckBox x:Name="OemCheckBox" />
                <Label Text="OEM"
                       VerticalOptions="Center" />
            </HorizontalStackLayout>
            <Button Text="In tem"
                    Clicked="OnPrintClicked" />
            <ActivityIndicator x:Name="LoadingIndicator"
                               IsVisible="False"
                               IsRunning="False" />
            <Label x:Name="MessageLabel"
                   TextColor="Red" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
