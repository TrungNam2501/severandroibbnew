<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BBK.Mobile.ScanPage"
             Title="Quét In Tem"
             BackgroundColor="{AppThemeBinding Light={StaticResource PageBackground}, Dark={StaticResource PageBackgroundDark}}">
    <ScrollView>
        <VerticalStackLayout Padding="16,10" Spacing="8">

            <!-- MES Section -->
            <Border StrokeShape="RoundRectangle 10"
                    Stroke="Transparent"
                    BackgroundColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource CardBackgroundDark}}"
                    Padding="14,10">
                <VerticalStackLayout Spacing="6">
                    <Label Text="Mã MES"
                           FontSize="12"
                           TextColor="{StaticResource Gray400}"
                           FontAttributes="Bold" />
                    <Picker x:Name="MesPicker"
                            Title="Chọn MES"
                            FontSize="15"
                            TextColor="{StaticResource Gray900}"
                            BackgroundColor="{AppThemeBinding Light={StaticResource InputBackground}, Dark={StaticResource InputBackgroundDark}}"
                            SelectedIndexChanged="OnMesSelected" />

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Mã Keo"
                                   FontSize="12"
                                   TextColor="{StaticResource Gray400}"
                                   FontAttributes="Bold" />
                            <Border StrokeShape="RoundRectangle 8"
                                    Stroke="{StaticResource Gray200}"
                                    BackgroundColor="{AppThemeBinding Light=#EDF2F7, Dark={StaticResource InputBackgroundDark}}"
                                    Padding="10,2"
                                    HeightRequest="38">
                                <Entry x:Name="RecipeEntry"
                                       Placeholder="Tự động"
                                       IsReadOnly="True"
                                       FontSize="14" />
                            </Border>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="End">
                            <HorizontalStackLayout Spacing="2">
                                <CheckBox x:Name="OemCheckBox"
                                          MinimumWidthRequest="32"
                                          MinimumHeightRequest="32" />
                                <Label Text="OEM"
                                       FontSize="13"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource Gray500}"
                                       VerticalOptions="Center" />
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Pallet + Weight Section -->
            <Border StrokeShape="RoundRectangle 10"
                    Stroke="Transparent"
                    BackgroundColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource CardBackgroundDark}}"
                    Padding="14,10">
                <VerticalStackLayout Spacing="6">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Mã Pallet"
                                   FontSize="12"
                                   TextColor="{StaticResource Gray400}"
                                   FontAttributes="Bold" />
                            <Border StrokeShape="RoundRectangle 8"
                                    Stroke="{StaticResource Gray200}"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource InputBackground}, Dark={StaticResource InputBackgroundDark}}"
                                    Padding="10,2"
                                    HeightRequest="38">
                                <Entry x:Name="PalletEntry"
                                       Placeholder="Quét mã pallet"
                                       FontSize="14"
                                       TextChanged="OnPalletTextChanged" />
                            </Border>
                        </VerticalStackLayout>
                        <RadioButton x:Name="SanXuatRadio"
                                     Grid.Column="1"
                                     Content="SXuất"
                                     IsVisible="False"
                                     VerticalOptions="End"
                                     CheckedChanged="OnSanXuatCheckedChanged" />
                    </Grid>

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Trọng Lượng (kg)"
                                   FontSize="12"
                                   TextColor="{StaticResource Gray400}"
                                   FontAttributes="Bold" />
                            <Border StrokeShape="RoundRectangle 8"
                                    Stroke="{StaticResource Gray200}"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource InputBackground}, Dark={StaticResource InputBackgroundDark}}"
                                    Padding="10,2"
                                    HeightRequest="38">
                                <Entry x:Name="WeightEntry"
                                       Placeholder="Nhập trọng lượng"
                                       Keyboard="Numeric"
                                       FontSize="14" />
                            </Border>
                        </VerticalStackLayout>
                        <RadioButton x:Name="CanDaoRadio"
                                     Grid.Column="1"
                                     Content="CĐảo"
                                     IsVisible="False"
                                     VerticalOptions="End"
                                     CheckedChanged="OnCanDaoCheckedChanged" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Printer Section -->
            <Border StrokeShape="RoundRectangle 10"
                    Stroke="Transparent"
                    BackgroundColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource CardBackgroundDark}}"
                    Padding="14,10">
                <VerticalStackLayout Spacing="4">
                    <Label Text="Máy In"
                           FontSize="12"
                           TextColor="{StaticResource Gray400}"
                           FontAttributes="Bold" />
                    <Picker x:Name="PrinterPicker"
                            Title="Chọn máy in"
                            ItemDisplayBinding="{Binding Name}"
                            FontSize="15"
                            TextColor="{StaticResource Gray900}"
                            BackgroundColor="{AppThemeBinding Light={StaticResource InputBackground}, Dark={StaticResource InputBackgroundDark}}" />
                </VerticalStackLayout>
            </Border>

            <!-- Action Buttons -->
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8" Padding="0,2">
                <Button Text="Làm mới"
                        FontSize="13"
                        BackgroundColor="Transparent"
                        TextColor="{StaticResource Gray500}"
                        BorderColor="{StaticResource Gray200}"
                        BorderWidth="1"
                        CornerRadius="10"
                        HeightRequest="40"
                        Clicked="OnResetClicked" />
                <Button Grid.Column="1"
                        Text="In Tem"
                        FontSize="13"
                        FontAttributes="Bold"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="White"
                        CornerRadius="10"
                        HeightRequest="40"
                        Clicked="OnPrintClicked" />
                <Button Grid.Column="2"
                        Text="Kết thúc"
                        FontSize="13"
                        BackgroundColor="{StaticResource Secondary}"
                        TextColor="White"
                        CornerRadius="10"
                        HeightRequest="40"
                        Clicked="OnFinishClicked" />
            </Grid>

            <!-- Loading + Message -->
            <ActivityIndicator x:Name="LoadingIndicator"
                               IsVisible="False"
                               IsRunning="False"
                               Color="{StaticResource Primary}"
                               HeightRequest="24" />
            <Label x:Name="MessageLabel"
                   FontSize="13"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
