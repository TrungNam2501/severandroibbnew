<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BBK.Mobile.ScanPage"
             Title="Quét Tem">
    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="14">
            <Label Text="Chọn Mã MES"
                   FontSize="20"
                   FontAttributes="Bold" />
            <Picker x:Name="MesPicker"
                    Title="Chọn MES"
                    SelectedIndexChanged="OnMesSelected" />
            <Label Text="Mã KEO"
                   FontSize="20"
                   FontAttributes="Bold" />
            <HorizontalStackLayout Spacing="8">
                <Entry x:Name="RecipeEntry"
                       Placeholder="Mã keo"
                       IsReadOnly="True"
                       HorizontalOptions="FillAndExpand" />
                <CheckBox x:Name="OemCheckBox" />
                <Label Text="OEM"
                       FontSize="20"
                       VerticalOptions="Center" />
            </HorizontalStackLayout>
            <Label Text="Mã PALET"
                   FontSize="20"
                   FontAttributes="Bold" />
            <HorizontalStackLayout Spacing="8">
                <Entry x:Name="PalletEntry"
                       Placeholder="Pallet"
                       TextChanged="OnPalletTextChanged"
                       HorizontalOptions="FillAndExpand" />
                <RadioButton x:Name="SanXuatRadio"
                             Content="SXuất"
                             IsVisible="False"
                             CheckedChanged="OnSanXuatCheckedChanged" />
            </HorizontalStackLayout>
            <Label Text="Nhập Trọng Lượng"
                   FontSize="20"
                   FontAttributes="Bold" />
            <HorizontalStackLayout Spacing="8">
                <Entry x:Name="WeightEntry"
                       Placeholder="Trọng lượng"
                       Keyboard="Numeric"
                       HorizontalOptions="FillAndExpand" />
                <RadioButton x:Name="CanDaoRadio"
                             Content="CĐảo"
                             IsVisible="False"
                             CheckedChanged="OnCanDaoCheckedChanged" />
            </HorizontalStackLayout>
            <Label Text="Chọn máy in"
                   FontSize="20"
                   FontAttributes="Bold" />
            <Picker x:Name="PrinterPicker"
                    Title="Chọn máy in"
                    ItemDisplayBinding="{Binding Name}" />
            <HorizontalStackLayout Spacing="12" HorizontalOptions="Center">
                <Button Text="Làm mới"
                        FontSize="14"
                        FontAttributes="Bold"
                        Clicked="OnResetClicked" />
                <Button Text="In Tem"
                        FontSize="14"
                        FontAttributes="Bold"
                        Clicked="OnPrintClicked" />
                <Button Text="Kết thúc"
                        FontSize="14"
                        FontAttributes="Bold"
                        Clicked="OnFinishClicked" />
            </HorizontalStackLayout>
            <ActivityIndicator x:Name="LoadingIndicator"
                               IsVisible="False"
                               IsRunning="False" />
            <Label x:Name="MessageLabel"
                   TextColor="Red" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
