<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BBK.Mobile.ScanPage"
             Title="Quét In Tem"
             BackgroundColor="{StaticResource PageBackground}">
    <ScrollView>
        <VerticalStackLayout Padding="20,12" Spacing="14">

            <!-- MES Section -->
            <Border StrokeShape="RoundRectangle 20"
                    Stroke="Transparent"
                    BackgroundColor="{StaticResource White}"
                    Padding="20,18"
                    Shadow="{OnPlatform Android={Shadow Brush=#10000000, Offset='0,2', Radius=12}}">
                <VerticalStackLayout Spacing="14">
                    <!-- MES Picker -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Mã MES"
                               FontSize="13"
                               TextColor="{StaticResource TextSecondary}"
                               FontAttributes="Bold" />
                        <Picker x:Name="MesPicker"
                                Title="Chọn MES"
                                FontSize="15"
                                TextColor="{StaticResource TextPrimary}"
                                TitleColor="{StaticResource TextMuted}"
                                BackgroundColor="{StaticResource InputBackground}"
                                SelectedIndexChanged="OnMesSelected" />
                    </VerticalStackLayout>

                    <!-- Recipe + OEM -->
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Mã Keo"
                                   FontSize="13"
                                   TextColor="{StaticResource TextSecondary}"
                                   FontAttributes="Bold" />
                            <Border StrokeShape="RoundRectangle 14"
                                    Stroke="Transparent"
                                    BackgroundColor="{StaticResource SurfaceElevated}"
                                    Padding="14,0"
                                    HeightRequest="48">
                                <Entry x:Name="RecipeEntry"
                                       Placeholder="Tự động"
                                       PlaceholderColor="{StaticResource TextMuted}"
                                       TextColor="{StaticResource Primary}"
                                       IsReadOnly="True"
                                       FontSize="15"
                                       FontAttributes="Bold" />
                            </Border>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="End">
                            <HorizontalStackLayout Spacing="4">
                                <CheckBox x:Name="OemCheckBox"
                                          Color="{StaticResource Primary}"
                                          MinimumWidthRequest="36"
                                          MinimumHeightRequest="36" />
                                <Label Text="OEM"
                                       FontSize="13"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource TextSecondary}"
                                       VerticalOptions="Center" />
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Pallet + Weight Section -->
            <Border StrokeShape="RoundRectangle 20"
                    Stroke="Transparent"
                    BackgroundColor="{StaticResource White}"
                    Padding="20,18"
                    Shadow="{OnPlatform Android={Shadow Brush=#10000000, Offset='0,2', Radius=12}}">
                <VerticalStackLayout Spacing="14">
                    <!-- Pallet -->
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Mã Pallet"
                                   FontSize="13"
                                   TextColor="{StaticResource TextSecondary}"
                                   FontAttributes="Bold" />
                            <Border StrokeShape="RoundRectangle 14"
                                    Stroke="Transparent"
                                    BackgroundColor="{StaticResource InputBackground}"
                                    Padding="14,0"
                                    HeightRequest="48">
                                <Entry x:Name="PalletEntry"
                                       Placeholder="Quét mã pallet"
                                       PlaceholderColor="{StaticResource TextMuted}"
                                       TextColor="{StaticResource TextPrimary}"
                                       FontSize="15"
                                       TextChanged="OnPalletTextChanged" />
                            </Border>
                        </VerticalStackLayout>
                        <RadioButton x:Name="SanXuatRadio"
                                     Grid.Column="1"
                                     Content="SXuất"
                                     TextColor="{StaticResource TextSecondary}"
                                     IsVisible="False"
                                     VerticalOptions="End"
                                     CheckedChanged="OnSanXuatCheckedChanged" />
                    </Grid>

                    <!-- Weight -->
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Trọng lượng (kg)"
                                   FontSize="13"
                                   TextColor="{StaticResource TextSecondary}"
                                   FontAttributes="Bold" />
                            <Border StrokeShape="RoundRectangle 14"
                                    Stroke="Transparent"
                                    BackgroundColor="{StaticResource InputBackground}"
                                    Padding="14,0"
                                    HeightRequest="48">
                                <Entry x:Name="WeightEntry"
                                       Placeholder="Nhập trọng lượng"
                                       PlaceholderColor="{StaticResource TextMuted}"
                                       TextColor="{StaticResource TextPrimary}"
                                       Keyboard="Numeric"
                                       FontSize="15" />
                            </Border>
                        </VerticalStackLayout>
                        <RadioButton x:Name="CanDaoRadio"
                                     Grid.Column="1"
                                     Content="CĐảo"
                                     TextColor="{StaticResource TextSecondary}"
                                     IsVisible="False"
                                     VerticalOptions="End"
                                     CheckedChanged="OnCanDaoCheckedChanged" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Printer Section -->
            <Border StrokeShape="RoundRectangle 20"
                    Stroke="Transparent"
                    BackgroundColor="{StaticResource White}"
                    Padding="20,18"
                    Shadow="{OnPlatform Android={Shadow Brush=#10000000, Offset='0,2', Radius=12}}">
                <VerticalStackLayout Spacing="6">
                    <Label Text="Máy In"
                           FontSize="13"
                           TextColor="{StaticResource TextSecondary}"
                           FontAttributes="Bold" />
                    <Picker x:Name="PrinterPicker"
                            Title="Chọn máy in"
                            ItemDisplayBinding="{Binding Name}"
                            FontSize="15"
                            TextColor="{StaticResource TextPrimary}"
                            TitleColor="{StaticResource TextMuted}"
                            BackgroundColor="{StaticResource InputBackground}" />
                </VerticalStackLayout>
            </Border>

            <!-- Action Buttons -->
            <Grid ColumnDefinitions="*,2*,*" ColumnSpacing="10" Padding="0,4">
                <Button Text="Làm mới"
                        FontSize="13"
                        BackgroundColor="{StaticResource White}"
                        TextColor="{StaticResource TextSecondary}"
                        CornerRadius="16"
                        HeightRequest="48"
                        Shadow="{OnPlatform Android={Shadow Brush=#08000000, Offset='0,1', Radius=6}}"
                        Clicked="OnResetClicked" />
                <Button Grid.Column="1"
                        Text="In Tem"
                        FontSize="16"
                        FontAttributes="Bold"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="White"
                        CornerRadius="16"
                        HeightRequest="48"
                        Clicked="OnPrintClicked" />
                <Button Grid.Column="2"
                        Text="Kết thúc"
                        FontSize="13"
                        BackgroundColor="{StaticResource Success}"
                        TextColor="White"
                        CornerRadius="16"
                        HeightRequest="48"
                        Clicked="OnFinishClicked" />
            </Grid>

            <!-- Loading + Message -->
            <ActivityIndicator x:Name="LoadingIndicator"
                               IsVisible="False"
                               IsRunning="False"
                               Color="{StaticResource Primary}"
                               HeightRequest="24" />
            <Label x:Name="MessageLabel"
                   FontSize="13"
                   TextColor="{StaticResource Danger}"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
