<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BBK.Mobile.MenuPage"
             Title="Chức năng"
             BackgroundColor="{StaticResource PageBackground}">

    <Grid RowDefinitions="Auto,*,Auto" Padding="0">

        <!-- User Info Header -->
        <Border Grid.Row="0"
                StrokeShape="RoundRectangle 0,0,14,14"
                Stroke="Transparent"
                BackgroundColor="{StaticResource SurfaceLight}"
                Padding="20,16">
            <HorizontalStackLayout Spacing="12">
                <Border StrokeShape="RoundRectangle 18"
                        Stroke="{StaticResource Primary}"
                        StrokeThickness="2"
                        BackgroundColor="{StaticResource InputBackground}"
                        HeightRequest="40"
                        WidthRequest="40">
                    <Label Text="&#x1F464;"
                           FontSize="18"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
                <VerticalStackLayout VerticalOptions="Center" Spacing="1">
                    <Label x:Name="UserLabel"
                           FontSize="15"
                           FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}" />
                    <Label x:Name="MachineLabel"
                           FontSize="12"
                           TextColor="{StaticResource TextMuted}" />
                </VerticalStackLayout>
            </HorizontalStackLayout>
        </Border>

        <!-- Menu Cards -->
        <VerticalStackLayout Grid.Row="1"
                             Padding="16,20"
                             Spacing="10"
                             VerticalOptions="Start">

            <!-- Scan Card -->
            <Border StrokeShape="RoundRectangle 10"
                    Stroke="{StaticResource BorderDark}"
                    StrokeThickness="1"
                    BackgroundColor="{StaticResource CardBackground}"
                    Padding="0">
                <Grid ColumnDefinitions="Auto,*,Auto"
                      Padding="16,14"
                      ColumnSpacing="14">
                    <Border StrokeShape="RoundRectangle 10"
                            Stroke="Transparent"
                            BackgroundColor="#38BDF820"
                            HeightRequest="42"
                            WidthRequest="42">
                        <Label Text="&#x1F4CB;"
                               FontSize="20"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Border>
                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="1">
                        <Label Text="Quét In Tem"
                               FontSize="15"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}" />
                        <Label Text="In tem mới cho mẻ keo"
                               FontSize="12"
                               TextColor="{StaticResource TextMuted}" />
                    </VerticalStackLayout>
                    <Label Grid.Column="2"
                           Text="›"
                           FontSize="24"
                           TextColor="{StaticResource Primary}"
                           VerticalOptions="Center" />
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnScanClicked" />
                    </Grid.GestureRecognizers>
                </Grid>
            </Border>

            <!-- Reprint Card -->
            <Border StrokeShape="RoundRectangle 10"
                    Stroke="{StaticResource BorderDark}"
                    StrokeThickness="1"
                    BackgroundColor="{StaticResource CardBackground}"
                    Padding="0">
                <Grid ColumnDefinitions="Auto,*,Auto"
                      Padding="16,14"
                      ColumnSpacing="14">
                    <Border StrokeShape="RoundRectangle 10"
                            Stroke="Transparent"
                            BackgroundColor="#10B98120"
                            HeightRequest="42"
                            WidthRequest="42">
                        <Label Text="&#x1F504;"
                               FontSize="20"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Border>
                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="1">
                        <Label Text="In Lại Tem"
                               FontSize="15"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}" />
                        <Label Text="In lại tem đã in trước đó"
                               FontSize="12"
                               TextColor="{StaticResource TextMuted}" />
                    </VerticalStackLayout>
                    <Label Grid.Column="2"
                           Text="›"
                           FontSize="24"
                           TextColor="{StaticResource Secondary}"
                           VerticalOptions="Center" />
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnReprintClicked" />
                    </Grid.GestureRecognizers>
                </Grid>
            </Border>

        </VerticalStackLayout>

        <!-- Logout -->
        <VerticalStackLayout Grid.Row="2"
                             Padding="16,0,16,20">
            <Button Text="Đăng xuất"
                    FontSize="13"
                    BackgroundColor="Transparent"
                    TextColor="{StaticResource Danger}"
                    BorderColor="{StaticResource BorderDark}"
                    BorderWidth="1"
                    CornerRadius="10"
                    HeightRequest="40"
                    Clicked="OnLogoutClicked" />
        </VerticalStackLayout>

    </Grid>
</ContentPage>
