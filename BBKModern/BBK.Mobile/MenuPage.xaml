<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BBK.Mobile.MenuPage"
             Title="Chức năng"
             BackgroundColor="{StaticResource PageBackground}">

    <Grid RowDefinitions="Auto,*,Auto" Padding="0">

        <!-- User Info -->
        <VerticalStackLayout Grid.Row="0"
                             Padding="24,20"
                             Spacing="2">
            <Label x:Name="UserLabel"
                   FontSize="20"
                   FontAttributes="Bold"
                   TextColor="{StaticResource TextPrimary}" />
            <Label x:Name="MachineLabel"
                   FontSize="13"
                   TextColor="{StaticResource TextMuted}" />
        </VerticalStackLayout>

        <!-- Menu Cards -->
        <VerticalStackLayout Grid.Row="1"
                             Padding="20,4"
                             Spacing="14"
                             VerticalOptions="Start">

            <!-- Scan Card -->
            <Border StrokeShape="RoundRectangle 20"
                    Stroke="Transparent"
                    BackgroundColor="{StaticResource White}"
                    Padding="0"
                    Shadow="{OnPlatform Android={Shadow Brush=#10000000, Offset='0,3', Radius=16}}">
                <Grid ColumnDefinitions="Auto,*,Auto"
                      Padding="20,20"
                      ColumnSpacing="16">
                    <Border StrokeShape="RoundRectangle 16"
                            Stroke="Transparent"
                            BackgroundColor="{StaticResource SurfaceElevated}"
                            HeightRequest="52"
                            WidthRequest="52">
                        <Label Text="&#x1F4CB;"
                               FontSize="24"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Border>
                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                        <Label Text="Quét In Tem"
                               FontSize="17"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}" />
                        <Label Text="In tem mới cho mẻ keo"
                               FontSize="13"
                               TextColor="{StaticResource TextMuted}" />
                    </VerticalStackLayout>
                    <Label Grid.Column="2"
                           Text="›"
                           FontSize="28"
                           TextColor="{StaticResource PrimaryLight}"
                           VerticalOptions="Center" />
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnScanClicked" />
                    </Grid.GestureRecognizers>
                </Grid>
            </Border>

            <!-- Reprint Card -->
            <Border StrokeShape="RoundRectangle 20"
                    Stroke="Transparent"
                    BackgroundColor="{StaticResource White}"
                    Padding="0"
                    Shadow="{OnPlatform Android={Shadow Brush=#10000000, Offset='0,3', Radius=16}}">
                <Grid ColumnDefinitions="Auto,*,Auto"
                      Padding="20,20"
                      ColumnSpacing="16">
                    <Border StrokeShape="RoundRectangle 16"
                            Stroke="Transparent"
                            BackgroundColor="#ECFDF5"
                            HeightRequest="52"
                            WidthRequest="52">
                        <Label Text="&#x1F504;"
                               FontSize="24"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Border>
                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                        <Label Text="In Lại Tem"
                               FontSize="17"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}" />
                        <Label Text="In lại tem đã in trước đó"
                               FontSize="13"
                               TextColor="{StaticResource TextMuted}" />
                    </VerticalStackLayout>
                    <Label Grid.Column="2"
                           Text="›"
                           FontSize="28"
                           TextColor="{StaticResource Success}"
                           VerticalOptions="Center" />
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnReprintClicked" />
                    </Grid.GestureRecognizers>
                </Grid>
            </Border>

        </VerticalStackLayout>

        <!-- Logout -->
        <VerticalStackLayout Grid.Row="2"
                             Padding="20,0,20,24">
            <Button Text="Đăng xuất"
                    FontSize="14"
                    BackgroundColor="Transparent"
                    TextColor="{StaticResource Danger}"
                    CornerRadius="16"
                    HeightRequest="48"
                    Clicked="OnLogoutClicked" />
        </VerticalStackLayout>

    </Grid>
</ContentPage>
