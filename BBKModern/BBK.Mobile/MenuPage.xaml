<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BBK.Mobile.MenuPage"
             Title="Chức năng"
             BackgroundColor="{AppThemeBinding Light={StaticResource PageBackground}, Dark={StaticResource PageBackgroundDark}}">

    <Grid RowDefinitions="Auto,*,Auto" Padding="0">

        <!-- User Info Header -->
        <Border Grid.Row="0"
                StrokeShape="RoundRectangle 0,0,16,16"
                Stroke="Transparent"
                BackgroundColor="{StaticResource Primary}"
                Padding="20,16">
            <HorizontalStackLayout Spacing="12">
                <Border StrokeShape="RoundRectangle 20"
                        Stroke="Transparent"
                        BackgroundColor="#FFFFFF30"
                        HeightRequest="40"
                        WidthRequest="40">
                    <Label Text="&#x1F464;"
                           FontSize="18"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
                <VerticalStackLayout VerticalOptions="Center" Spacing="1">
                    <Label x:Name="UserLabel"
                           FontSize="15"
                           FontAttributes="Bold"
                           TextColor="White" />
                    <Label x:Name="MachineLabel"
                           FontSize="12"
                           TextColor="#B3D4FC" />
                </VerticalStackLayout>
            </HorizontalStackLayout>
        </Border>

        <!-- Menu Cards -->
        <VerticalStackLayout Grid.Row="1"
                             Padding="16,20"
                             Spacing="12"
                             VerticalOptions="Start">

            <!-- Scan Button Card -->
            <Border StrokeShape="RoundRectangle 12"
                    Stroke="Transparent"
                    BackgroundColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource CardBackgroundDark}}"
                    Shadow="{OnPlatform Android={Shadow Brush=#20000000, Offset='0,2', Radius=6}}">
                <Grid ColumnDefinitions="Auto,*,Auto"
                      Padding="16,14"
                      ColumnSpacing="14">
                    <Border StrokeShape="RoundRectangle 12"
                            Stroke="Transparent"
                            BackgroundColor="#E3F2FD"
                            HeightRequest="44"
                            WidthRequest="44">
                        <Label Text="&#x1F4CB;"
                               FontSize="20"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Border>
                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="1">
                        <Label Text="Quét In Tem"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}" />
                        <Label Text="In tem mới cho mẻ keo"
                               FontSize="12"
                               TextColor="{StaticResource Gray400}" />
                    </VerticalStackLayout>
                    <Label Grid.Column="2"
                           Text=">"
                           FontSize="18"
                           TextColor="{StaticResource Gray300}"
                           VerticalOptions="Center" />
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnScanClicked" />
                    </Grid.GestureRecognizers>
                </Grid>
            </Border>

            <!-- Reprint Button Card -->
            <Border StrokeShape="RoundRectangle 12"
                    Stroke="Transparent"
                    BackgroundColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource CardBackgroundDark}}"
                    Shadow="{OnPlatform Android={Shadow Brush=#20000000, Offset='0,2', Radius=6}}">
                <Grid ColumnDefinitions="Auto,*,Auto"
                      Padding="16,14"
                      ColumnSpacing="14">
                    <Border StrokeShape="RoundRectangle 12"
                            Stroke="Transparent"
                            BackgroundColor="#E8F5E9"
                            HeightRequest="44"
                            WidthRequest="44">
                        <Label Text="&#x1F504;"
                               FontSize="20"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Border>
                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="1">
                        <Label Text="In Lại Tem"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}" />
                        <Label Text="In lại tem đã in trước đó"
                               FontSize="12"
                               TextColor="{StaticResource Gray400}" />
                    </VerticalStackLayout>
                    <Label Grid.Column="2"
                           Text=">"
                           FontSize="18"
                           TextColor="{StaticResource Gray300}"
                           VerticalOptions="Center" />
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnReprintClicked" />
                    </Grid.GestureRecognizers>
                </Grid>
            </Border>

        </VerticalStackLayout>

        <!-- Logout Button -->
        <VerticalStackLayout Grid.Row="2"
                             Padding="16,0,16,20">
            <Button Text="Đăng xuất"
                    FontSize="14"
                    BackgroundColor="Transparent"
                    TextColor="{StaticResource Danger}"
                    BorderColor="{StaticResource Gray200}"
                    BorderWidth="1"
                    CornerRadius="12"
                    HeightRequest="42"
                    Clicked="OnLogoutClicked" />
        </VerticalStackLayout>

    </Grid>
</ContentPage>
