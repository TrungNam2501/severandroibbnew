<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Brand Colors - Industrial Blue Theme -->
    <Color x:Key="Primary">#1565C0</Color>
    <Color x:Key="PrimaryDark">#0D47A1</Color>
    <Color x:Key="PrimaryDarkText">#FFFFFF</Color>
    <Color x:Key="PrimaryLight">#42A5F5</Color>
    <Color x:Key="Secondary">#00897B</Color>
    <Color x:Key="SecondaryDarkText">#B2DFDB</Color>
    <Color x:Key="Tertiary">#FF6F00</Color>
    <Color x:Key="Accent">#26A69A</Color>
    <Color x:Key="Danger">#E53935</Color>
    <Color x:Key="Success">#43A047</Color>
    <Color x:Key="Warning">#FB8C00</Color>

    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="Black">#000000</Color>
    <Color x:Key="Magenta">#D600AA</Color>
    <Color x:Key="MidnightBlue">#0D1B2A</Color>
    <Color x:Key="OffBlack">#1B2838</Color>

    <!-- Surface Colors -->
    <Color x:Key="PageBackground">#F0F4F8</Color>
    <Color x:Key="CardBackground">#FFFFFF</Color>
    <Color x:Key="CardBackgroundDark">#1E2A3A</Color>
    <Color x:Key="PageBackgroundDark">#0F1923</Color>
    <Color x:Key="InputBackground">#F5F7FA</Color>
    <Color x:Key="InputBackgroundDark">#263242</Color>

    <Color x:Key="Gray100">#E8EDF2</Color>
    <Color x:Key="Gray200">#CBD5E0</Color>
    <Color x:Key="Gray300">#A0AEC0</Color>
    <Color x:Key="Gray400">#718096</Color>
    <Color x:Key="Gray500">#4A5568</Color>
    <Color x:Key="Gray600">#2D3748</Color>
    <Color x:Key="Gray900">#1A202C</Color>
    <Color x:Key="Gray950">#0F1318</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}"/>
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource Tertiary}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}"/>

    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}"/>
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}"/>
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}"/>
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}"/>
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}"/>
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}"/>
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}"/>
    <SolidColorBrush x:Key="Gray950Brush" Color="{StaticResource Gray950}"/>
</ResourceDictionary>
