<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Clean Minimal Theme -->
    <Color x:Key="Primary">#7C3AED</Color>
    <Color x:Key="PrimaryDark">#6D28D9</Color>
    <Color x:Key="PrimaryDarkText">#FFFFFF</Color>
    <Color x:Key="PrimaryLight">#A78BFA</Color>
    <Color x:Key="Secondary">#06B6D4</Color>
    <Color x:Key="SecondaryDarkText">#CFFAFE</Color>
    <Color x:Key="Tertiary">#F59E0B</Color>
    <Color x:Key="Accent">#7C3AED</Color>
    <Color x:Key="Danger">#EF4444</Color>
    <Color x:Key="Success">#10B981</Color>
    <Color x:Key="Warning">#F59E0B</Color>

    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="Black">#000000</Color>
    <Color x:Key="Magenta">#D600AA</Color>
    <Color x:Key="MidnightBlue">#1E1B4B</Color>
    <Color x:Key="OffBlack">#0F0D1A</Color>

    <!-- Surface Colors - Light & Clean -->
    <Color x:Key="PageBackground">#F8F7FC</Color>
    <Color x:Key="CardBackground">#FFFFFF</Color>
    <Color x:Key="CardBackgroundDark">#1E1B4B</Color>
    <Color x:Key="PageBackgroundDark">#0F0D1A</Color>
    <Color x:Key="InputBackground">#F3F0FF</Color>
    <Color x:Key="InputBackgroundDark">#2D2A5E</Color>
    <Color x:Key="SurfaceLight">#FFFFFF</Color>
    <Color x:Key="SurfaceElevated">#EDE9FE</Color>
    <Color x:Key="BorderDark">#E5E1F5</Color>

    <!-- Gray Palette -->
    <Color x:Key="Gray100">#F5F3FF</Color>
    <Color x:Key="Gray200">#E5E1F5</Color>
    <Color x:Key="Gray300">#C4B5FD</Color>
    <Color x:Key="Gray400">#8B83A3</Color>
    <Color x:Key="Gray500">#6B6380</Color>
    <Color x:Key="Gray600">#4C4563</Color>
    <Color x:Key="Gray900">#1E1B4B</Color>
    <Color x:Key="Gray950">#0F0D1A</Color>

    <!-- Text Colors -->
    <Color x:Key="TextPrimary">#1E1B4B</Color>
    <Color x:Key="TextSecondary">#6B6380</Color>
    <Color x:Key="TextMuted">#8B83A3</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}"/>
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource Tertiary}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}"/>

    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}"/>
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}"/>
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}"/>
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}"/>
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}"/>
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}"/>
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}"/>
    <SolidColorBrush x:Key="Gray950Brush" Color="{StaticResource Gray950}"/>
</ResourceDictionary>
