<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BBK.Mobile.MainPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource Primary}">

    <Grid RowDefinitions="Auto,*"
          Padding="0">

        <!-- Header -->
        <VerticalStackLayout Grid.Row="0"
                             Padding="24,40,24,20"
                             Spacing="2">
            <Label Text="BBK LABEL"
                   FontSize="32"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalOptions="Center" />
            <Label Text="Hệ thống in tem keo"
                   FontSize="14"
                   TextColor="#B3D4FC"
                   HorizontalOptions="Center" />
        </VerticalStackLayout>

        <!-- Login Card -->
        <Border Grid.Row="1"
                StrokeShape="RoundRectangle 24,24,0,0"
                Stroke="Transparent"
                BackgroundColor="{AppThemeBinding Light={StaticResource PageBackground}, Dark={StaticResource PageBackgroundDark}}"
                Padding="0"
                VerticalOptions="Fill">
            <ScrollView>
                <VerticalStackLayout Padding="24,24" Spacing="14">

                    <!-- Employee Number -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Mã số thẻ"
                               FontSize="13"
                               TextColor="{StaticResource Gray400}"
                               FontAttributes="Bold" />
                        <Border StrokeShape="RoundRectangle 10"
                                Stroke="{StaticResource Gray200}"
                                BackgroundColor="{AppThemeBinding Light={StaticResource InputBackground}, Dark={StaticResource InputBackgroundDark}}"
                                Padding="14,2"
                                HeightRequest="44">
                            <Entry x:Name="EmployeeEntry"
                                   Placeholder="Nhập 6 chữ số..."
                                   Keyboard="Numeric"
                                   MaxLength="6"
                                   FontSize="16"
                                   TextChanged="OnEmployeeTextChanged" />
                        </Border>
                    </VerticalStackLayout>

                    <!-- Machine Picker -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Chọn máy"
                               FontSize="13"
                               TextColor="{StaticResource Gray400}"
                               FontAttributes="Bold" />
                        <Picker x:Name="MachinePicker"
                                Title="Chọn máy sản xuất"
                                ItemDisplayBinding="{Binding Name}"
                                FontSize="15"
                                BackgroundColor="{AppThemeBinding Light={StaticResource InputBackground}, Dark={StaticResource InputBackgroundDark}}"
                                TextColor="{StaticResource Gray900}" />
                    </VerticalStackLayout>

                    <!-- Message -->
                    <Label x:Name="MessageLabel"
                           FontSize="14"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center" />

                    <!-- Loading -->
                    <ActivityIndicator x:Name="LoadingIndicator"
                                       IsVisible="False"
                                       IsRunning="False"
                                       Color="{StaticResource Primary}"
                                       HeightRequest="30" />

                    <!-- Login Button -->
                    <Button Text="Đăng Nhập"
                            FontSize="17"
                            FontAttributes="Bold"
                            BackgroundColor="{StaticResource Primary}"
                            TextColor="White"
                            CornerRadius="12"
                            HeightRequest="48"
                            Clicked="OnLoginClicked" />

                    <!-- Exit Button -->
                    <Button Text="Thoát"
                            FontSize="14"
                            BackgroundColor="Transparent"
                            TextColor="{StaticResource Gray400}"
                            BorderColor="{StaticResource Gray200}"
                            BorderWidth="1"
                            CornerRadius="12"
                            HeightRequest="42"
                            Clicked="OnExitClicked" />

                </VerticalStackLayout>
            </ScrollView>
        </Border>

    </Grid>
</ContentPage>
