<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BBK.Mobile.MainPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource PageBackground}">

    <ScrollView>
        <VerticalStackLayout Padding="32,60,32,32" Spacing="0">

            <!-- Logo KENDA -->
            <VerticalStackLayout Spacing="10" Margin="0,0,0,40">
                <Image Source="kenda_icon.png"
                       HeightRequest="80"
                       WidthRequest="80"
                       Aspect="AspectFit"
                       HorizontalOptions="Center" />
                <Label Text="BBK Label"
                       FontSize="28"
                       FontAttributes="Bold"
                       TextColor="{StaticResource TextPrimary}"
                       HorizontalOptions="Center" />
                <Label Text="Hệ thống in tem keo"
                       FontSize="14"
                       TextColor="{StaticResource TextMuted}"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>

            <!-- Employee Number -->
            <VerticalStackLayout Spacing="8" Margin="0,0,0,20">
                <Label Text="Mã số thẻ"
                       FontSize="14"
                       TextColor="{StaticResource TextSecondary}"
                       FontAttributes="Bold" />
                <Entry x:Name="EmployeeEntry"
                       Placeholder="Nhập 6 chữ số..."
                       PlaceholderColor="{StaticResource TextMuted}"
                       TextColor="{StaticResource TextPrimary}"
                       Keyboard="Numeric"
                       MaxLength="6"
                       FontSize="17"
                       BackgroundColor="{StaticResource White}"
                       TextChanged="OnEmployeeTextChanged" />
            </VerticalStackLayout>

            <!-- Machine Picker -->
            <VerticalStackLayout Spacing="8" Margin="0,0,0,24">
                <Label Text="Chọn máy"
                       FontSize="14"
                       TextColor="{StaticResource TextSecondary}"
                       FontAttributes="Bold" />
                <Picker x:Name="MachinePicker"
                        Title="Chọn máy sản xuất"
                        ItemDisplayBinding="{Binding Name}"
                        FontSize="16"
                        TextColor="{StaticResource TextPrimary}"
                        TitleColor="{StaticResource TextMuted}"
                        BackgroundColor="{StaticResource White}" />
            </VerticalStackLayout>

            <!-- Message -->
            <Label x:Name="MessageLabel"
                   FontSize="13"
                   TextColor="{StaticResource Danger}"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"
                   Margin="0,0,0,8" />

            <!-- Loading -->
            <ActivityIndicator x:Name="LoadingIndicator"
                               IsVisible="False"
                               IsRunning="False"
                               Color="{StaticResource Primary}"
                               HeightRequest="28" />

            <!-- Login Button -->
            <Button Text="Đăng Nhập"
                    FontSize="17"
                    FontAttributes="Bold"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="White"
                    CornerRadius="16"
                    HeightRequest="56"
                    Margin="0,0,0,12"
                    Clicked="OnLoginClicked" />

            <!-- Exit Button -->
            <Button Text="Thoát"
                    FontSize="14"
                    BackgroundColor="Transparent"
                    TextColor="{StaticResource TextMuted}"
                    CornerRadius="16"
                    HeightRequest="48"
                    Clicked="OnExitClicked" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
