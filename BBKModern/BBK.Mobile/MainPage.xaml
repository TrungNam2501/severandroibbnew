<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BBK.Mobile.MainPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource PageBackground}">

    <Grid RowDefinitions="Auto,*"
          Padding="0">

        <!-- Header -->
        <VerticalStackLayout Grid.Row="0"
                             Padding="24,44,24,20"
                             Spacing="4">
            <Label Text="BBK LABEL"
                   FontSize="34"
                   FontAttributes="Bold"
                   TextColor="{StaticResource Primary}"
                   HorizontalOptions="Center" />
            <Label Text="Hệ thống in tem keo"
                   FontSize="13"
                   TextColor="{StaticResource TextMuted}"
                   HorizontalOptions="Center" />
            <BoxView HeightRequest="1"
                     BackgroundColor="{StaticResource BorderDark}"
                     Margin="40,10,40,0" />
        </VerticalStackLayout>

        <!-- Login Form -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="24,8,24,24" Spacing="14">

                <!-- Employee Number -->
                <VerticalStackLayout Spacing="4">
                    <Label Text="MÃ SỐ THẺ"
                           FontSize="11"
                           TextColor="{StaticResource TextMuted}"
                           FontAttributes="Bold"
                           CharacterSpacing="1" />
                    <Border StrokeShape="RoundRectangle 8"
                            Stroke="{StaticResource BorderDark}"
                            BackgroundColor="{StaticResource InputBackground}"
                            Padding="14,2"
                            HeightRequest="44">
                        <Entry x:Name="EmployeeEntry"
                               Placeholder="Nhập 6 chữ số..."
                               PlaceholderColor="{StaticResource TextMuted}"
                               TextColor="{StaticResource TextPrimary}"
                               Keyboard="Numeric"
                               MaxLength="6"
                               FontSize="16"
                               TextChanged="OnEmployeeTextChanged" />
                    </Border>
                </VerticalStackLayout>

                <!-- Machine Picker -->
                <VerticalStackLayout Spacing="4">
                    <Label Text="CHỌN MÁY"
                           FontSize="11"
                           TextColor="{StaticResource TextMuted}"
                           FontAttributes="Bold"
                           CharacterSpacing="1" />
                    <Picker x:Name="MachinePicker"
                            Title="Chọn máy sản xuất"
                            ItemDisplayBinding="{Binding Name}"
                            FontSize="15"
                            TextColor="{StaticResource TextPrimary}"
                            TitleColor="{StaticResource TextMuted}"
                            BackgroundColor="{StaticResource InputBackground}" />
                </VerticalStackLayout>

                <!-- Message -->
                <Label x:Name="MessageLabel"
                       FontSize="13"
                       TextColor="{StaticResource Warning}"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center" />

                <!-- Loading -->
                <ActivityIndicator x:Name="LoadingIndicator"
                                   IsVisible="False"
                                   IsRunning="False"
                                   Color="{StaticResource Primary}"
                                   HeightRequest="28" />

                <!-- Login Button -->
                <Button Text="Đăng Nhập"
                        FontSize="16"
                        FontAttributes="Bold"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="{StaticResource PageBackground}"
                        CornerRadius="10"
                        HeightRequest="48"
                        Clicked="OnLoginClicked" />

                <!-- Exit Button -->
                <Button Text="Thoát"
                        FontSize="13"
                        BackgroundColor="Transparent"
                        TextColor="{StaticResource TextMuted}"
                        BorderColor="{StaticResource BorderDark}"
                        BorderWidth="1"
                        CornerRadius="10"
                        HeightRequest="40"
                        Clicked="OnExitClicked" />

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
